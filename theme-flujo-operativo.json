{
  "name": "Flujo Operativo-Financiero",
  "dataColors": [
    "#2563EB",
    "#60A5FA",
    "#F59E0B",
    "#EF4444",
    "#10B981",
    "#6366F1",
    "#8B5CF6",
    "#EC4899",
    "#14B8A6",
    "#F97316"
  ],
  "background": "#F1F5F9",
  "foreground": "#1E293B",
  "tableAccent": "#2563EB",
  "good": "#10B981",
  "neutral": "#F59E0B",
  "bad": "#EF4444",
  "maximum": "#EF4444",
  "center": "#F59E0B",
  "minimum": "#10B981",
  "textClasses": {
    "callout": {
      "fontSize": 28,
      "fontFace": "Segoe UI Semibold",
      "color": "#0F172A"
    },
    "title": {
      "fontSize": 16,
      "fontFace": "Segoe UI Semibold",
      "color": "#1E293B"
    },
    "header": {
      "fontSize": 13,
      "fontFace": "Segoe UI Semibold",
      "color": "#334155"
    },
    "label": {
      "fontSize": 11,
      "fontFace": "Segoe UI",
      "color": "#64748B"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [{ "color": { "solid": { "color": "#FFFFFF" } }, "transparency": 0 }],
        "border": [{ "color": { "solid": { "color": "#E2E8F0" } }, "radius": 12 }],
        "dropShadow": [{ "show": true, "color": { "solid": { "color": "#00000010" } }, "position": "Outer", "preset": "BottomRight" }],
        "padding": [{ "top": 12, "bottom": 12, "left": 16, "right": 16 }],
        "title": [{
          "show": true,
          "fontColor": { "solid": { "color": "#1E293B" } },
          "fontSize": 13,
          "fontFamily": "Segoe UI Semibold",
          "alignment": "left"
        }]
      }
    },
    "card": {
      "*": {
        "labels": [{ "fontSize": 28, "fontFamily": "Segoe UI Semibold", "color": { "solid": { "color": "#0F172A" } } }],
        "categoryLabels": [{ "fontSize": 11, "fontFamily": "Segoe UI", "color": { "solid": { "color": "#64748B" } } }]
      }
    },
    "slicer": {
      "*": {
        "background": [{ "color": { "solid": { "color": "#FFFFFF" } }, "transparency": 0 }],
        "items": [{ "fontColor": { "solid": { "color": "#334155" } }, "fontSize": 11, "fontFamily": "Segoe UI" }],
        "header": [{ "fontColor": { "solid": { "color": "#64748B" } }, "fontSize": 11, "fontFamily": "Segoe UI" }]
      }
    },
    "page": {
      "*": {
        "background": [{ "color": { "solid": { "color": "#F1F5F9" } }, "transparency": 0 }]
      }
    }
  }
}
